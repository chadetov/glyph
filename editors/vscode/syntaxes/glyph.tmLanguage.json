{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Glyph",
  "scopeName": "source.glyph",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#calls" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.glyph",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.glyph",
          "begin": "\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.double.glyph",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.glyph", "match": "\\\\." },
            {
              "name": "meta.template.expression.glyph",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.glyph" } },
              "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.glyph" } },
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "entity.name.tag.annotation.glyph",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(fn|component)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.glyph" },
            "2": { "name": "entity.name.function.glyph" }
          }
        },
        {
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.glyph" },
            "2": { "name": "entity.name.type.glyph" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.glyph",
          "match": "\\b(match|return|loop|for|in|break|continue|else|is|await)\\b"
        },
        {
          "name": "keyword.declaration.glyph",
          "match": "\\b(fn|type|component|const|let|mut|import|module|async|owned|resource)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.glyph",
          "match": "\\b(true|false|void)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.glyph",
          "match": "\\b(string|number|bool|unknown)\\b"
        },
        {
          "name": "entity.name.type.glyph",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.glyph",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "name": "entity.name.function.call.glyph",
          "match": "\\b[a-z_][A-Za-z0-9_]*(?=\\()"
        }
      ]
    }
  }
}
